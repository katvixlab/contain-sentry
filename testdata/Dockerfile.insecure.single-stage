# ============================================================
# ТЕСТОВЫЙ single-stage Dockerfile
# Нужен специально для проверки DF004:
# Single-stage image contains build tooling
# ============================================================

# ------------------------------------------------------------
# DF002: Base image tag without digest
# ------------------------------------------------------------
FROM ubuntu:22.04

# ------------------------------------------------------------
# DF004: Single-stage image contains build tooling
# Здесь в single-stage образ ставятся gcc, make, build-essential.
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y build-essential gcc make

# ------------------------------------------------------------
# Дополнительно здесь может сработать DF018,
# если твой движок проверяет отсутствие cleanup.
# ------------------------------------------------------------

CMD ["bash", "-lc", "echo single-stage build tooling present"]