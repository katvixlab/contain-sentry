# ============================================================
# ТЕСТОВЫЙ Dockerfile ДЛЯ ПРОВЕРКИ ПРАВИЛ DF001–DF022
# Этот файл специально содержит нарушения.
#
# Покрывает:
# DF001, DF002, DF003, DF005, DF006, DF007, DF008, DF009,
# DF010, DF011, DF012, DF013, DF014, DF015, DF016, DF017,
# DF018, DF019, DF020, DF021, DF022
#
# Не покрывает:
# DF004 — для него нужен отдельный single-stage Dockerfile
# ============================================================


# ------------------------------------------------------------
# DF001: Base image uses latest tag
# DF002: Base image tag without digest
# Здесь deliberately используется latest без digest.
# ------------------------------------------------------------
FROM alpine:latest AS builder

# ------------------------------------------------------------
# DF009: Secret-like ARG key detected
# ARG с секретоподобным именем.
# ------------------------------------------------------------
ARG AWS_SECRET_KEY=super-secret-build-key

# ------------------------------------------------------------
# DF008: Secret-like ENV key detected
# ENV с секретоподобным именем.
# ------------------------------------------------------------
ENV APP_PASSWORD=supersecret

# ------------------------------------------------------------
# DF015: Prefer COPY over ADD for local files
# DF011: ADD may include secret file
# Локальный ADD + секретоподобный файл.
# ------------------------------------------------------------
ADD .env /tmp/.env

# ------------------------------------------------------------
# DF014: ADD URL without checksum
# DF015: Prefer COPY over ADD for local files / ADD usage
# Загрузка по URL через ADD.
# ------------------------------------------------------------
ADD https://example.com/archive.tar.gz /tmp/archive.tar.gz

# ------------------------------------------------------------
# DF010: COPY may include secret file
# COPY секретного файла.
# ------------------------------------------------------------
COPY id_rsa /root/.ssh/id_rsa

# ------------------------------------------------------------
# DF012: curl/wget piped to shell
# DF013: curl/wget without verification
# Опасный паттерн: скачать и сразу выполнить.
# ------------------------------------------------------------
RUN curl -fsSL https://example.com/install.sh | sh

# ------------------------------------------------------------
# DF016: apt-get update is separate from install
# Отдельный RUN с update без install.
# ------------------------------------------------------------
RUN apt-get update

# ------------------------------------------------------------
# DF017: apt upgrade detected
# Использование apt-get upgrade.
# ------------------------------------------------------------
RUN apt-get upgrade -y

# ------------------------------------------------------------
# DF018: apt-get install without apt lists cleanup
# install без rm -rf /var/lib/apt/lists/*
# ------------------------------------------------------------
RUN apt-get install -y curl git

# ------------------------------------------------------------
# DF019: apk add without --no-cache
# Для alpine — apk add без --no-cache.
# ------------------------------------------------------------
RUN apk add bash

# ------------------------------------------------------------
# DF020: Cache mount without id
# BuildKit cache mount без id.
# ------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apk \
    echo "cache without id"

# ------------------------------------------------------------
# DF021: Apt cache mount without sharing=locked
# mount для apt без sharing=locked.
# ------------------------------------------------------------
RUN --mount=type=cache,target=/var/lib/apt,id=apt-cache \
    apt-get update


# ------------------------------------------------------------
# DF002: Base image tag without digest
# Финальная стадия тоже без digest.
# ------------------------------------------------------------
FROM debian:12

# ------------------------------------------------------------
# DF006: USER is root or uid 0
# Явный запуск от root.
# ------------------------------------------------------------
USER root

# ------------------------------------------------------------
# DF007: USER uid must be greater than 1000
# Ниже оставлен альтернативный вариант проверки uid<=1000.
# Для проверки DF007 можно заменить USER root на USER 1000
# и прогонять файл второй раз.
# ------------------------------------------------------------
# USER 1000

# ------------------------------------------------------------
# DF003: Final stage in multi-stage misses COPY --from
# Здесь НЕТ COPY --from=builder, хотя Dockerfile multi-stage.
# Это специально.
# ------------------------------------------------------------

# ------------------------------------------------------------
# DF005: Missing USER in final stage
# В текущем варианте DF005 НЕ сработает, потому что USER root задан.
# Для проверки DF005 нужно временно закомментировать USER root выше.
# ------------------------------------------------------------

# ------------------------------------------------------------
# DF022: Missing HEALTHCHECK in final stage
# HEALTHCHECK намеренно отсутствует.
# ------------------------------------------------------------

CMD ["sh", "-c", "echo insecure runtime"]